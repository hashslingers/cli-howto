def search(query: str) -> list[tuple[str, dict]]:
    q = query.lower()
    results = []
    for pattern, data in COMMANDS.items():
        phrases = [k.strip() for k in pattern.split("|")]
        # Match if ALL words in any phrase appear in the query
        if any(all(w in q for w in p.split()) for p in phrases):
            results.append((pattern, data))
    return results


def display(matches: list[tuple[str, dict]]) -> None:
    for _, data in matches:
        print(f"\n📖  {data['title']}")
        print("─" * 50)
        for cmd, desc in data["examples"]:
            print(f"  {cmd:<40}  # {desc}")
    print()


def main():
    if len(sys.argv) < 2:
        print("Usage: howto <your question>")
        print('Example: howto "how do I delete a directory"')
        sys.exit(0)

    query = " ".join(sys.argv[1:])
    matches = search(query)

    if not matches:
        print(f'\n🤔  No results for "{query}"')
        print("Try keywords like: delete, copy, move, find, list, permission, process, history\n")
    else:
        display(matches)


if __name__ == "__main__":
    main()
