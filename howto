#!/usr/bin/env python3
"""howto - LLM-powered CLI learning assistant (Gemini Flash)."""

import sys
import os
import time
import warnings

# Suppress deprecation warnings
warnings.filterwarnings("ignore", category=FutureWarning)

import google.generativeai as genai
from rich.console import Console
from rich.markdown import Markdown
from rich.panel import Panel

console = Console()

SYSTEM_PROMPT = """You are a concise command line teacher for macOS/Linux.
When asked how to do something in the terminal:
- Give the exact command(s) to use in `code blocks`
- Use **bold** for key terms and parameters
- Use ### Headers for different sections or variations
- Add a brief explanation of what each does and why
- Keep it focused and practical — the user is learning as they work
- NO intros or outros. Jump straight to the headers.
- Format strictly like this:
  ### Primary Command
  `command`
  **Description:** Brief explanation...

  ### Variation
  `command --flag`
  **Description:** Brief explanation..."""

def ask(question: str) -> str:
    api_key = os.environ.get("GEMINI_API_KEY")
    if not api_key:
        console.print("[red]Error: GEMINI_API_KEY not set[/red]")
        console.print("Run: export GEMINI_API_KEY=your_key")
        sys.exit(1)

    try:
        genai.configure(api_key=api_key)
        model = genai.GenerativeModel(
            model_name="gemini-2.5-flash",
            system_instruction=SYSTEM_PROMPT,
        )
        start_time = time.time()
        response = model.generate_content(question)
        elapsed = time.time() - start_time
        return response.text, elapsed
    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")
        sys.exit(1)

def main():
    if len(sys.argv) < 2:
        console.print("[cyan]howto[/cyan] — LLM-powered CLI learning assistant")
        console.print()
        console.print("[bold]Usage:[/bold]")
        console.print("  howto <your question>")
        console.print()
        console.print("[bold]Examples:[/bold]")
        console.print('  howto "how do I delete a directory"')
        console.print('  howto "move a file to another folder"')
        console.print('  howto "check what is using port 8080"')
        sys.exit(0)

    # Handle help flags
    if sys.argv[1] in ["-h", "--help", "help"]:
        sys.argv = [sys.argv[0]]  # Reuse help text above
        main()
        return

    question = " ".join(sys.argv[1:])
    console.print(Panel(f"[bold white]{question}[/bold white]", title="[bold blue]Question[/bold blue]", border_style="blue"))
    
    with console.status("[bold green]Thinking...", spinner="dots"):
        result, elapsed = ask(question)
        
    console.print(Panel(Markdown(result, code_theme="monokai"), border_style="green", title="[bold green]Answer[/bold green]"))
    console.print(f"[dim italic]Completed in {elapsed:.2f}s[/dim italic]")

if __name__ == "__main__":
    main()
